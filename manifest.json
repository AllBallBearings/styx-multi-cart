{
  "manifest_version": 3,
  "name": "Styx Multi-Cart",
  "version": "1.0.0",
  "description": "Styx — save, switch, and ferry between multiple Amazon shopping carts with one click.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://amazon.com/*",
    "*://*.amazon.com/*",
    "*://amazon.co.uk/*",
    "*://*.amazon.co.uk/*",
    "*://amazon.ca/*",
    "*://*.amazon.ca/*",
    "*://amazon.com.au/*",
    "*://*.amazon.com.au/*",
    "*://amazon.de/*",
    "*://*.amazon.de/*",
    "*://amazon.fr/*",
    "*://*.amazon.fr/*",
    "*://amazon.it/*",
    "*://*.amazon.it/*",
    "*://amazon.es/*",
    "*://*.amazon.es/*",
    "*://amazon.co.jp/*",
    "*://*.amazon.co.jp/*",
    "*://amazon.in/*",
    "*://*.amazon.in/*",
    "*://amazon.com.mx/*",
    "*://*.amazon.com.mx/*",
    "*://amazon.com.br/*",
    "*://*.amazon.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Styx Multi-Cart"
  },
  "content_scripts": [
    {
      "matches": [
        "*://amazon.com/gp/cart*",
        "*://*.amazon.com/gp/cart/*",
        "*://*.amazon.com/gp/cart*",
        "*://amazon.com/cart*",
        "*://*.amazon.com/cart/*",
        "*://*.amazon.com/cart*",
        "*://amazon.co.uk/gp/cart*",
        "*://*.amazon.co.uk/gp/cart/*",
        "*://*.amazon.co.uk/gp/cart*",
        "*://amazon.co.uk/cart*",
        "*://*.amazon.co.uk/cart/*",
        "*://*.amazon.co.uk/cart*",
        "*://amazon.ca/gp/cart*",
        "*://*.amazon.ca/gp/cart/*",
        "*://*.amazon.ca/gp/cart*",
        "*://amazon.ca/cart*",
        "*://*.amazon.ca/cart/*",
        "*://*.amazon.ca/cart*",
        "*://amazon.com.au/gp/cart*",
        "*://*.amazon.com.au/gp/cart/*",
        "*://*.amazon.com.au/gp/cart*",
        "*://amazon.com.au/cart*",
        "*://*.amazon.com.au/cart*",
        "*://amazon.de/gp/cart*",
        "*://*.amazon.de/gp/cart/*",
        "*://*.amazon.de/gp/cart*",
        "*://amazon.de/cart*",
        "*://*.amazon.de/cart*",
        "*://amazon.fr/gp/cart*",
        "*://*.amazon.fr/gp/cart/*",
        "*://*.amazon.fr/gp/cart*",
        "*://amazon.fr/cart*",
        "*://*.amazon.fr/cart*",
        "*://amazon.it/gp/cart*",
        "*://*.amazon.it/gp/cart/*",
        "*://*.amazon.it/gp/cart*",
        "*://amazon.it/cart*",
        "*://*.amazon.it/cart*",
        "*://amazon.es/gp/cart*",
        "*://*.amazon.es/gp/cart/*",
        "*://*.amazon.es/gp/cart*",
        "*://amazon.es/cart*",
        "*://*.amazon.es/cart*",
        "*://amazon.co.jp/gp/cart*",
        "*://*.amazon.co.jp/gp/cart/*",
        "*://*.amazon.co.jp/gp/cart*",
        "*://amazon.co.jp/cart*",
        "*://*.amazon.co.jp/cart*",
        "*://amazon.in/gp/cart*",
        "*://*.amazon.in/gp/cart/*",
        "*://*.amazon.in/gp/cart*",
        "*://amazon.in/cart*",
        "*://*.amazon.in/cart*",
        "*://amazon.com.mx/gp/cart*",
        "*://*.amazon.com.mx/gp/cart/*",
        "*://*.amazon.com.mx/gp/cart*",
        "*://amazon.com.mx/cart*",
        "*://*.amazon.com.mx/cart*",
        "*://amazon.com.br/gp/cart*",
        "*://*.amazon.com.br/gp/cart/*",
        "*://*.amazon.com.br/gp/cart*",
        "*://amazon.com.br/cart*",
        "*://*.amazon.com.br/cart*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

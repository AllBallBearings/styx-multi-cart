    "*://amazon.in/*",
    "*://*.amazon.in/*",
    "*://amazon.com.mx/*",
    "*://*.amazon.com.mx/*",
    "*://amazon.com.br/*",
    "*://*.amazon.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Styx Multi-Cart",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"

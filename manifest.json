{
  "manifest_version": 3,
  "name": "Styx Multi-Cart",
  "version": "0.9.3",
  "author": "Jared Goolsby",
  "homepage_url": "https://allballbearings.github.io/styx-multi-cart/",
  "description": "Save, switch, and restore multiple Amazon shopping carts. Local-only storage, no tracking, no account required.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://amazon.com/*",
    "*://*.amazon.com/*",
    "*://amazon.co.uk/*",
    "*://*.amazon.co.uk/*",
    "*://amazon.ca/*",
    "*://*.amazon.ca/*",
    "*://amazon.com.au/*",
    "*://*.amazon.com.au/*",
    "*://amazon.de/*",
    "*://*.amazon.de/*",
    "*://amazon.fr/*",
    "*://*.amazon.fr/*",
    "*://amazon.it/*",
    "*://*.amazon.it/*",
    "*://amazon.es/*",
    "*://*.amazon.es/*",
    "*://amazon.co.jp/*",
    "*://*.amazon.co.jp/*",
    "*://amazon.in/*",
    "*://*.amazon.in/*",
    "*://amazon.com.mx/*",
    "*://*.amazon.com.mx/*",
    "*://amazon.com.br/*",
    "*://*.amazon.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Styx Multi-Cart",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://amazon.com/gp/cart*",
        "*://*.amazon.com/gp/cart/*",
        "*://*.amazon.com/gp/cart*",
        "*://amazon.com/cart*",
        "*://*.amazon.com/cart/*",
        "*://*.amazon.com/cart*",
        "*://amazon.co.uk/gp/cart*",
        "*://*.amazon.co.uk/gp/cart/*",
        "*://*.amazon.co.uk/gp/cart*",
        "*://amazon.co.uk/cart*",
        "*://*.amazon.co.uk/cart/*",
        "*://*.amazon.co.uk/cart*",
        "*://amazon.ca/gp/cart*",
        "*://*.amazon.ca/gp/cart/*",
        "*://*.amazon.ca/gp/cart*",
        "*://amazon.ca/cart*",
        "*://*.amazon.ca/cart/*",
        "*://*.amazon.ca/cart*",
        "*://amazon.com.au/gp/cart*",
        "*://*.amazon.com.au/gp/cart/*",
        "*://*.amazon.com.au/gp/cart*",
        "*://amazon.com.au/cart*",
        "*://*.amazon.com.au/cart*",
        "*://amazon.de/gp/cart*",
        "*://*.amazon.de/gp/cart/*",
        "*://*.amazon.de/gp/cart*",
        "*://amazon.de/cart*",
        "*://*.amazon.de/cart*",
        "*://amazon.fr/gp/cart*",
        "*://*.amazon.fr/gp/cart/*",
        "*://*.amazon.fr/gp/cart*",
        "*://amazon.fr/cart*",
        "*://*.amazon.fr/cart*",
        "*://amazon.it/gp/cart*",
        "*://*.amazon.it/gp/cart/*",
        "*://*.amazon.it/gp/cart*",
        "*://amazon.it/cart*",
        "*://*.amazon.it/cart*",
        "*://amazon.es/gp/cart*",
        "*://*.amazon.es/gp/cart/*",
        "*://*.amazon.es/gp/cart*",
        "*://amazon.es/cart*",
        "*://*.amazon.es/cart*",
        "*://amazon.co.jp/gp/cart*",
        "*://*.amazon.co.jp/gp/cart/*",
        "*://*.amazon.co.jp/gp/cart*",
        "*://amazon.co.jp/cart*",
        "*://*.amazon.co.jp/cart*",
        "*://amazon.in/gp/cart*",
        "*://*.amazon.in/gp/cart/*",
        "*://*.amazon.in/gp/cart*",
        "*://amazon.in/cart*",
        "*://*.amazon.in/cart*",
        "*://amazon.com.mx/gp/cart*",
        "*://*.amazon.com.mx/gp/cart/*",
        "*://*.amazon.com.mx/gp/cart*",
        "*://amazon.com.mx/cart*",
        "*://*.amazon.com.mx/cart*",
        "*://amazon.com.br/gp/cart*",
        "*://*.amazon.com.br/gp/cart/*",
        "*://*.amazon.com.br/gp/cart*",
        "*://amazon.com.br/cart*",
        "*://*.amazon.com.br/cart*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://amazon.ca/*",
        "*://*.amazon.com.au/*",
        "*://amazon.com.au/*",
        "*://*.amazon.de/*",
        "*://amazon.de/*",
        "*://*.amazon.fr/*",
        "*://amazon.fr/*",
        "*://*.amazon.it/*",
        "*://amazon.it/*",
        "*://*.amazon.es/*",
        "*://amazon.es/*",
        "*://*.amazon.co.jp/*",
        "*://amazon.co.jp/*",
        "*://*.amazon.in/*",
        "*://amazon.in/*",
        "*://*.amazon.com.mx/*",
        "*://amazon.com.mx/*",
        "*://*.amazon.com.br/*",
        "*://amazon.com.br/*"
      ],
      "js": ["observer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["ExtPay.js"],
      "run_at": "document_start"
    }
  ]
}

    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://amazon.com/*",
    "*://*.amazon.com/*",
    "*://amazon.co.uk/*",
    "*://*.amazon.co.uk/*",
    "*://amazon.ca/*",
    "*://*.amazon.ca/*",
    "*://amazon.com.au/*",
    "*://*.amazon.com.au/*",
    "*://amazon.de/*",
